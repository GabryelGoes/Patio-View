# ===== Painel de TV (unificado Pátio/Laboratório) =====

# Modo do painel: "patio" (padrão) ou "laboratorio".
# Define quadro, cores, colunas e qual escopo da API é consumido.
VITE_TV_MODE=patio

# URL base da API do sistema de gestão (incluindo /api)
# Ex.: https://seu-app.vercel.app/api
# Em outro domínio: configure CORS no backend para o origin deste painel.
VITE_API_BASE=

# (Opcional) Token de leitura da TV — deve casar com TV_API_TOKEN no servidor.
VITE_TV_TOKEN=
